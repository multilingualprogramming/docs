# Search with for-else
let target = 7
let numbers = [1, 3, 5, 7, 9]

for num in numbers:
    if num == target:
        print(f"Found {target}")
        break
else:
    print(f"{target} not found")

# While-else
let x = 10
while x > 0:
    x -= 3
    if x == 1:
        break
else:
    print("loop finished normally")
